#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 *
 * @file console
 * @author Gaspard Kirira
 *
 * Copyright 2026, Gaspard Kirira.
 * All rights reserved.
 * https://github.com/iviphp/ivi
