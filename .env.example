```dotenv
# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

APP_NAME="Ivi Application"
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://example.com
# APP_TIMEZONE=Africa/Kampala
# APP_LOCALE=fr


# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# Active database connection.
#
# Supported examples:
# sqlite
# mysql
# pgsql

DB_DRIVER=sqlite


# ------------------------------------------------------------------------------
# SQLite
# ------------------------------------------------------------------------------

DB_DATABASE=storage/database.sqlite

# DB_FOREIGN_KEYS=true
# DB_BUSY_TIMEOUT=5000
# DB_JOURNAL_MODE=WAL
# DB_SYNCHRONOUS=NORMAL


# ------------------------------------------------------------------------------
# MySQL
# ------------------------------------------------------------------------------

# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=ivi
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_PREFIX=
# DB_STRICT=true


# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------

# DB_DRIVER=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=ivi
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_CHARSET=utf8
# DB_SCHEMA=public
# DB_PREFIX=


# ------------------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------------------

CACHE_DRIVER=file
CACHE_PATH=storage/cache
CACHE_PREFIX=ivi_

# In-memory cache for tests or short-lived processes.
# CACHE_DRIVER=array

# Database-backed cache.
# CACHE_DRIVER=database
# CACHE_TABLE=cache

# Redis-backed cache.
# CACHE_DRIVER=redis
# CACHE_CONNECTION=default


# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

LOG_CHANNEL=file
LOG_LEVEL=debug
LOG_PATH=storage/logs/app.log

# Write logs to standard error.
# LOG_CHANNEL=stderr

# Disable application logging.
# LOG_CHANNEL=null

# Production logging example.
# LOG_CHANNEL=file
# LOG_LEVEL=warning
# LOG_PATH=storage/logs/app.log


# ------------------------------------------------------------------------------
# HTTP
# ------------------------------------------------------------------------------

# HTTP_HOST=127.0.0.1
# HTTP_PORT=8000
# HTTP_TRUST_PROXIES=false
# HTTP_MAX_BODY_SIZE=10485760
# HTTP_FORCE_HTTPS=false


# ------------------------------------------------------------------------------
# Sessions
# ------------------------------------------------------------------------------

# SESSION_DRIVER=file
# SESSION_LIFETIME=120
# SESSION_PATH=storage/sessions
# SESSION_COOKIE=ivi_session
# SESSION_SECURE_COOKIE=false
# SESSION_HTTP_ONLY=true
# SESSION_SAME_SITE=lax

# Database-backed sessions.
# SESSION_DRIVER=database
# SESSION_TABLE=sessions

# Redis-backed sessions.
# SESSION_DRIVER=redis
# SESSION_CONNECTION=default


# ------------------------------------------------------------------------------
# Views
# ------------------------------------------------------------------------------

# VIEW_PATH=views
# VIEW_CACHE_PATH=storage/views
# VIEW_CACHE=true

# Disable compiled-view caching during development.
# VIEW_CACHE=false


# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------

# AUTH_GUARD=session
# AUTH_PROVIDER=users
# AUTH_PASSWORD_TIMEOUT=10800

# AUTH_USER_TABLE=users
# AUTH_IDENTIFIER_COLUMN=email
# AUTH_PASSWORD_COLUMN=password


# ------------------------------------------------------------------------------
# Queues
# ------------------------------------------------------------------------------

# Execute queued jobs immediately.
# QUEUE_DRIVER=sync

# Store queued jobs in the database.
# QUEUE_DRIVER=database
# QUEUE_TABLE=jobs
# QUEUE_FAILED_TABLE=failed_jobs

# Redis-backed queues.
# QUEUE_DRIVER=redis
# QUEUE_CONNECTION=default
# QUEUE_NAME=default


# ------------------------------------------------------------------------------
# Mail
# ------------------------------------------------------------------------------

# MAIL_DRIVER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=
# MAIL_FROM_ADDRESS=hello@example.com
# MAIL_FROM_NAME="${APP_NAME}"

# Production SMTP example.
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=user@example.com
# MAIL_PASSWORD=secret
# MAIL_ENCRYPTION=tls

# Write mail content to the application log.
# MAIL_DRIVER=log


# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------

# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# REDIS_CACHE_DATABASE=1
# REDIS_PREFIX=ivi_


# ------------------------------------------------------------------------------
# Filesystem
# ------------------------------------------------------------------------------

# FILESYSTEM_DRIVER=local
# FILESYSTEM_ROOT=storage/app
# FILESYSTEM_PUBLIC_ROOT=storage/app/public
# FILESYSTEM_PUBLIC_URL="${APP_URL}/storage"

# S3-compatible storage.
# FILESYSTEM_DRIVER=s3
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=
# S3_ENDPOINT=
# S3_PATH_STYLE=false


# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------

# Generate a secure secret before production deployment.
# APP_KEY=

# CORS_ALLOWED_ORIGINS=http://localhost:3000
# CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
# CORS_ALLOW_CREDENTIALS=true

# CSRF_ENABLED=true
# CSRF_TOKEN_NAME=_token
# CSRF_HEADER=X-CSRF-TOKEN


# ------------------------------------------------------------------------------
# Debug
# ------------------------------------------------------------------------------

# DEBUG_ENABLED=true
# DEBUG_DISPLAY_ERRORS=true
# DEBUG_LOG_ERRORS=true
# DEBUG_SHOW_TRACE=true

# Production example.
# DEBUG_ENABLED=false
# DEBUG_DISPLAY_ERRORS=false
# DEBUG_LOG_ERRORS=true
# DEBUG_SHOW_TRACE=false
```
