{
  "name": "iviphp/ivi",
  "description": "The official application skeleton for building modular web and console applications with IviPHP.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "iviphp/framework": "^0.1.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"is_dir('storage/cache') || mkdir('storage/cache', 0775, true);\"",
      "@php -r \"is_dir('storage/logs') || mkdir('storage/logs', 0775, true);\"",
      "@php -r \"is_dir('storage/views') || mkdir('storage/views', 0775, true);\""
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": {
  }
}
